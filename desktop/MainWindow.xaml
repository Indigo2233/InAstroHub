<Window x:Class="AstroDeviceHub.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Astro Device Hub" Width="1320" Height="850" MinWidth="1050" MinHeight="680"
        WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="CanResizeWithGrip"
        Background="{StaticResource WindowBackground}">
    <Window.Resources>
        <Style x:Key="WindowButton" TargetType="Button"><Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="#91A4AE"/><Setter Property="BorderThickness" Value="0"/><Setter Property="FontSize" Value="14"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#182832"/><Setter Property="Foreground" Value="#EAF4F7"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WindowButton}"><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#C94B55"/><Setter Property="Foreground" Value="White"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
    </Window.Resources>
    <Border BorderBrush="#253742" BorderThickness="1" CornerRadius="8" Background="#071016">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="46"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#0A151D" BorderBrush="#1D303B" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <Border Width="25" Height="25" CornerRadius="7" Background="#49D7CF">
                            <TextBlock Text="✦" Foreground="#062126" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Astro Device Hub" Foreground="#E8F2F5" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <Border Background="#102B2D" CornerRadius="10" Padding="8,3" Margin="14,0,0,0">
                            <StackPanel Orientation="Horizontal"><Ellipse Width="6" Height="6" Fill="#4AD8CF" Margin="0,0,6,0"/><TextBlock Text="SERVER ONLINE" Foreground="#77E3DC" FontSize="9" FontWeight="Bold"/></StackPanel>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="—" Width="46" Height="45" Style="{StaticResource WindowButton}" Click="Minimize_Click"/>
                        <Button Content="□" Width="46" Height="45" Style="{StaticResource WindowButton}" Click="Maximize_Click"/>
                        <Button Content="×" Width="46" Height="45" Style="{StaticResource CloseButton}" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
            <Grid Grid.Row="1">
                <wv2:WebView2 x:Name="Browser" DefaultBackgroundColor="#071016"/>
                <Border x:Name="LoadingPanel" Background="#071016">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="✦" Foreground="#49D7CF" FontSize="42" HorizontalAlignment="Center"/>
                        <TextBlock Text="正在启动设备中心…" Foreground="#A5B5BD" FontSize="14" Margin="0,14,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
